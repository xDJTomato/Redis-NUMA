# workload_baseline - YCSB 基线测试工作负载
#
# 目标: 验证功能正确性，建立性能基线
# 场景: 读写混合，均匀分布，轻量参数
# 参数由 run_ycsb.sh --mode baseline 覆盖:
#   recordcount=100000  operationcount=100000  threadcount=4

recordcount=100000
operationcount=100000
workload=site.ycsb.workloads.CoreWorkload

# 读写比例: 经典 50% 读 / 50% 更新
readproportion=0.5
updateproportion=0.5
scanproportion=0
insertproportion=0

# 均匀访问分布，消除热点干扰
requestdistribution=uniform

# 字段配置: 单字段，1KB value，覆盖 Pool 分配路径
fieldcount=1
fieldlength=1024
fieldlengthdistribution=constant

# 插入顺序: 哈希分布
insertorder=hashed

# Redis 连接（run_ycsb.sh 会通过 -p 参数覆盖）
redis.host=127.0.0.1
redis.port=6379
redis.timeout=5000
redis.database=0
