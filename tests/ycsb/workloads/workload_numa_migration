# workload_numa_migration - YCSB NUMA 迁移触发工作负载
#
# 目标: 触发跨 NUMA 节点的热点数据迁移
# 场景: Zipfian 倾斜分布 + 高并发 + 大数据量
# 预期: 50万条记录，200万次操作，触发数百次迁移

# ============================================================
# 基础配置
# ============================================================
recordcount=500000
operationcount=2000000
workload=site.ycsb.workloads.CoreWorkload

# ============================================================
# 操作比例: 写密集，触发内存分配与更新
# ============================================================
readproportion=0.4
updateproportion=0.5
scanproportion=0
insertproportion=0.1

# ============================================================
# 热点分布 - 关键配置
# ============================================================
# 使用 Zipfian 分布，α=0.99 产生强烈热点
# 约 1% 的 key 接收 90% 的访问
requestdistribution=zipfian
zipfianconstant=0.99

# 备选: 使用 Hotspot 模式 (更极端)
# requestdistribution=hotspot
# hotspotdatafraction=0.05    # 5% 的 key
# hotspotopnfraction=0.95     # 95% 的操作集中访问这些 key

# ============================================================
# 字段配置: 2KB value，覆盖 Pool 分配路径 (128B - 4KB)
# ============================================================
# 50万条 * 2KB ≈ 1GB 总数据量
fieldcount=1
fieldlength=2048
fieldlengthdistribution=constant

# ============================================================
# 插入顺序: 哈希分布，确保 NUMA 交错分配
# ============================================================
insertorder=hashed

# ============================================================
# Redis 连接 (脚本会通过 -p 参数覆盖)
# ============================================================
redis.host=127.0.0.1
redis.port=6379
redis.timeout=10000
redis.database=0
