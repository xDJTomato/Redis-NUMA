{
    // ────────────────────────────────────────────────────────────────
    // composite_lru.json  —  NUMA Composite-LRU 策略参数配置文件
    //
    // 加载方式（二选一）：
    //   1. redis.conf 中设置：
    //        numa-migrate-config /path/to/composite_lru.json
    //      Redis 启动时自动加载。
    //
    //   2. 运行时热更新（无需重启）：
    //        NUMA CONFIG LOAD /path/to/composite_lru.json
    //
    // 所有字段均为可选；未填写的字段保持程序内置默认值。
    // ────────────────────────────────────────────────────────────────

    // ── 热度衰减 ──────────────────────────────────────────────────
    // 惰性阶梯衰减的最小触发间隔（秒）。
    // Key 在上次访问后至少空闲 decay_threshold_sec 秒才会被衰减。
    // 较小的值使热度衰减更灵敏，过小会导致热点频繁重算。
    // 范围: 1 ~ 3600   默认: 10
    "decay_threshold_sec": 10,

    // ── 迁移触发阈值 ──────────────────────────────────────────────
    // Key 的热度等级达到此值时，候选池快速通道触发迁移评估。
    // 热度等级范围 0-7（PREFIX 机制追踪），值越小迁移越激进。
    // 范围: 1 ~ 7   默认: 5
    "migrate_hotness_threshold": 3,

    // ── 稳定性计数 ────────────────────────────────────────────────
    // 字典回退路径（非 PREFIX 场景）中，Key 需要连续满足迁移条件
    // stability_count 次后才真正触发迁移，防止抖动。
    // 范围: 1 ~ 255   默认: 3
    "stability_count": 3,

    // ── 候选池容量 ────────────────────────────────────────────────
    // 热点候选池（快速通道）环形缓冲区容量，单位：条目数。
    // 建议设置为 peak_hot_keys * 1.5。
    //   - 太小：高热度 key 被覆盖，迁移响应延迟升高
    //   - 太大：内存开销增加，收益递减
    // 适合场景：
    //   小实例（< 1M keys）: 256
    //   中实例（1-10M keys）: 512 ~ 1024
    //   大实例（> 10M keys）: 2048+
    // 范围: 1 ~ 65535   默认: 256
    "hot_candidates_size": 1024,

    // ── 渐进扫描批量大小 ──────────────────────────────────────────
    // 兜底通道：每次 serverCron tick 扫描的 key 数量。
    // 值越大，全量扫描一遍数据库越快，但每个 tick 的 CPU 消耗越高。
    // 建议：DBSIZE / 100 ~ DBSIZE / 50 （覆盖时间约 50-100 轮 cron）
    //   - 数据库 10W keys：200 ~ 400
    //   - 数据库 100W keys：2000 ~ 5000
    // 范围: 1 ~ 65535   默认: 200
    "scan_batch_size": 500,

    // ── 资源压力阈值（0.0 ~ 1.0）─────────────────────────────────
    // 以下三个阈值控制迁移执行时的资源保护逻辑。
    // 超过阈值时，迁移候选会进入延迟队列而非立即执行。

    // 节点内存利用率上限，超过则认为该节点"过载"，停止迁入。
    // 范围: 0.5 ~ 1.0   默认: 0.8
    "overload_threshold": 0.8,

    // 节点带宽利用率上限，超过则认为"带宽饱和"，限制迁移流量。
    // 范围: 0.5 ~ 1.0   默认: 0.9
    "bandwidth_threshold": 0.9,

    // 系统整体迁移压力上限，超过则进入保守模式（降低迁移速率）。
    // 范围: 0.3 ~ 1.0   默认: 0.7
    "pressure_threshold": 0.7,

    // ── 后台自动迁移开关 ──────────────────────────────────────────
    // 1 = 开启（推荐生产环境）：serverCron 自动驱动候选池 + 渐进扫描
    // 0 = 关闭：仅支持手动触发（NUMA MIGRATE KEY / NUMA MIGRATE SCAN）
    //           适合测试、调试或对迁移时机要求严格的场景
    // 默认: 1
    "auto_migrate_enabled": 1,

    // ── 节点最大带宽配置（MB/s）───────────────────────────────────
    // C-TAP 实测基线带宽，用于带宽利用率计算
    // Node 0 (CXL内存): 典型值 51000 MB/s (约 51 GB/s)
    // Node 1 (本地内存): 典型值 12000 MB/s (约 12 GB/s)
    // 根据实际硬件配置调整
    "max_bandwidth_node0_mbps": 51000,
    "max_bandwidth_node1_mbps": 12000
}
